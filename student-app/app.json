{
  "expo": {
    "name": "Myhomework",
    "slug": "myhomework-student",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "studentapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "uz.myhomework.student"
    },
    "android": {
      "package": "uz.myhomework.student",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#7B61FF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "Myhomework — O'quvchi",
      "shortName": "Myhomework",
      "themeColor": "#7B61FF",
      "backgroundColor": "#F0F2F8",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#F0F2F8"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/student"
    }
  }
}
