PORT=3000
JWT_SECRET=your-super-secret-key-change-in-production
LEADS_WEBHOOK_SECRET=your-leads-webhook-secret-change-in-production

# PostgreSQL ulanish (MAJBURIY)
# VPS uchun: postgresql://user:password@localhost:5432/myhomework
# Railway/Render uchun: ular avtomatik beradi
DATABASE_URL=postgresql://myhomework:password@localhost:5432/myhomework

# SSL: localhost uchun false, remote uchun true (yoki o'chiring)
DATABASE_SSL=false

# Avatar va fayllar uchun papka (deployment vaqtida yo'qolmasin)
# DATA_DIR=/var/lib/myhomework

# Admin parolini majburiy qayta o'rnatish uchun (bir marta, keyin o'chiring):
# ADMIN_INIT_PASSWORD=admin123
