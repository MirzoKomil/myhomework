# ── Asosiy sozlamalar ────────────────────────────────────────────────────────
PORT=3000

# ── MAJBURIY: ishlab chiqarish uchun o'zgartiring ────────────────────────────
# Kamida 32 ta tasodifiy belgi: openssl rand -hex 32
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING

# Webhook uchun alohida sir so'z
LEADS_WEBHOOK_SECRET=CHANGE_THIS_TO_ANOTHER_RANDOM_STRING

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://myhomework:strong_password@localhost:5432/myhomework
DATABASE_SSL=false

# ── CORS: ruxsat berilgan domenlar (vergul bilan ajratilgan) ─────────────────
ALLOWED_ORIGINS=https://myhomework.uz,https://www.myhomework.uz

# ── Fayllar (deployment vaqtida saqlansin) ───────────────────────────────────
# DATA_DIR=/var/lib/myhomework

# ── Admin parolini bir marta reset qilish (ishlatib o'chiring) ───────────────
# ADMIN_INIT_PASSWORD=admin123
